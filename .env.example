# PulseBoard Environment Configuration

# API Gateway
API_GATEWAY_PORT=8000
LOG_LEVEL=INFO
# メトリクス名ごとのインメモリ保持件数上限（超過分は FIFO で破棄、0 以下で無制限）
# MAX_METRICS_PER_NAME=1000
# GET /api/v1/metrics の既定ページサイズ
# METRICS_DEFAULT_LIMIT=100
# GET /api/v1/metrics の limit 上限
# METRICS_MAX_LIMIT=1000

# Metrics Worker
WORKER_PORT=8001
# /api/v1/aggregate のリクエストボディ最大バイト数（0 以下で無効化）
# MAX_AGGREGATE_BODY_BYTES=1048576
# values 配列の最大要素数（0 以下で無効化）
# MAX_AGGREGATE_VALUES=10000
# HTTP サーバのタイムアウト秒（Slowloris 等の対策）
# WORKER_READ_HEADER_TIMEOUT=5
# WORKER_READ_TIMEOUT=15
# WORKER_WRITE_TIMEOUT=15
# WORKER_IDLE_TIMEOUT=60

# Dashboard BFF
BFF_PORT=8002
API_GATEWAY_URL=http://api-gateway:8000
WORKER_URL=http://metrics-worker:8001
# ダッシュボードストアの保持件数上限（超過分は FIFO で破棄、0 以下で無制限）
# MAX_DASHBOARD_METRICS=10000
# express.json のリクエストボディ上限
# MAX_REQUEST_BODY=100kb
# GET /api/v1/dashboard/summary の limit 上限
# MAX_SUMMARY_LIMIT=500
